{
  "name": "codexmap",
  "version": "0.1.0-alpha.1",
  "description": "Live Codebase Intelligence & Context Drift Detection — Built by @Somu.ai for OpenAI Codex Hackathon 2025",
  "main": "bin/codexmap.js",
  "files": [
    "agents/*.js",
    "bin",
    "engines/*.js",
    "lib/*.js",
    "scripts/check-js.js",
    "scripts/cli-ux-test.sh",
    "scripts/clean.js",
    "scripts/clean_session.js",
    "scripts/cross_encoder_score.py",
    "scripts/cyclomatic.js",
    "scripts/embed.js",
    "scripts/eval/*.js",
    "scripts/eval/*.py",
    "scripts/eval/ground_truth.json",
    "scripts/fake-engine-e2e.sh",
    "scripts/integration-test.sh",
    "scripts/package-contents-test.js",
    "scripts/package-smoke-test.sh",
    "scripts/pageindex_adapter.py",
    "scripts/pageindex_build.py",
    "scripts/real-codex-smoke.sh",
    "scripts/release-preflight.sh",
    "scripts/unit-tests.js",
    "ui",
    "docs/*.md",
    "config.js",
    "orchestrator.js",
    "serve.js",
    "start.js",
    "version.js",
    "README.md",
    "ARCHITECTURE.md",
    "DEPLOYMENT.md",
    "PRODUCTION_READINESS.md",
    "WEBSOCKET.md",
    "SCORING.md",
    "RELEASE.md",
    "requirements.txt"
  ],
  "bin": {
    "codexmap": "bin/codexmap.js"
  },
  "scripts": {
    "start": "node bin/codexmap.js run",
    "dev": "node bin/codexmap.js run --engine fake --no-open --no-cloud-scoring \"Develop CodexMap safely\"",
    "check": "node scripts/check-js.js",
    "test": "node scripts/unit-tests.js",
    "test:python-wrapper": "python3 -m py_compile python-wrapper/src/codexmap/*.py",
    "test:cli-ux": "bash scripts/cli-ux-test.sh",
    "test:package": "node scripts/package-contents-test.js",
    "test:integration": "bash scripts/integration-test.sh",
    "test:e2e:fake": "bash scripts/fake-engine-e2e.sh",
    "test:e2e:codex": "bash scripts/real-codex-smoke.sh",
    "pack:smoke": "bash scripts/package-smoke-test.sh",
    "release:preflight": "bash scripts/release-preflight.sh",
    "eval": "node scripts/eval/run-all.js",
    "clean": "node scripts/clean.js",
    "install-all": "bash install.sh",
    "doctor": "node bin/codexmap.js doctor",
    "health": "curl -s http://localhost:3333/api/health | json_pp"
  },
  "dependencies": {
    "@babel/parser": "^7.24.0",
    "@babel/traverse": "^7.29.0",
    "chokidar": "^3.6.0",
    "cytoscape": "^3.28.1",
    "express": "^5.2.1",
    "openai": "^6.35.0",
    "simple-git": "^3.36.0",
    "ws": "^8.16.0"
  },
  "author": "@Somu.ai",
  "license": "MIT",
  "devDependencies": {
    "tree-sitter": "^0.25.0",
    "tree-sitter-go": "^0.25.0",
    "tree-sitter-javascript": "^0.25.0",
    "tree-sitter-python": "^0.25.0"
  }
}
